VITE_HOME_BACKGROUND_URL=

# Backend
APP_ENV=local
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=paris_ai_agent
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
GOOGLE_CLIENT_ID=393918443085-skalp5qspqm9cebl9akg5cf0modu3l3e.apps.googleusercontent.com
GOOGLE_PLACES_API_KEY=
ENABLE_GOOGLE_FOOD_SEARCH=true
GOOGLE_ROUTES_API_KEY=

# For production, provide real RSA PEM values. Local development will generate
# an ephemeral RSA key pair if these are empty.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALLOW_INSECURE_DEV_AUTH=true

# Optional external integrations
# Leave empty to use the default Open-Meteo forecast endpoint.
WEATHER_API_URL=
WEATHER_CACHE_TTL_MINUTES=30
EXTERNAL_AGENT_API_URL=
LLM_DIARY_API_URL=

# OpenAI (자연어 파싱 및 AI 추천)
OPENAI_API_KEY=

# Flight & Hotel search (RapidAPI)
# Kiwi.com Flights API: https://rapidapi.com/kiwi-com-kiwi-com-default/api/kiwi-com-flights-api
# Booking.com API: https://rapidapi.com/booking-com15/api/booking-com15
RAPIDAPI_KEY=
KIWI_RAPIDAPI_HOST=kiwi-com-flights-api.p.rapidapi.com
BOOKING_RAPIDAPI_HOST=booking-com15.p.rapidapi.com
