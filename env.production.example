# Frontend build-time values are injected by GitHub Actions when the frontend
# image is published. The values below are for server-side runtime services.

# Backend
APP_ENV=production
# Leave the default value below to use the MongoDB container from
# infra/docker-compose.prod.yml. Replace it with an Atlas URI if you want to
# use an external managed database instead.
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=paris_ai_agent
FRONTEND_ORIGIN=https://your-domain.example
GOOGLE_CLIENT_ID=
GOOGLE_PLACES_API_KEY=
ENABLE_GOOGLE_FOOD_SEARCH=true
GOOGLE_ROUTES_API_KEY=

# JWT
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALLOW_INSECURE_DEV_AUTH=false

# Optional external integrations
WEATHER_API_URL=
WEATHER_CACHE_TTL_MINUTES=30
EXTERNAL_AGENT_API_URL=
LLM_DIARY_API_URL=
OPENAI_API_KEY=

# Flight & Hotel search
RAPIDAPI_KEY=
KIWI_RAPIDAPI_HOST=kiwi-com-flights-api.p.rapidapi.com
BOOKING_RAPIDAPI_HOST=booking-com15.p.rapidapi.com
